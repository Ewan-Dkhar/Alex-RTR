# =============================================================
# Alex-RTR Backend Environment Configuration
# =============================================================

# --- LLM Configuration ---
# Replace with your actual ngrok URL (e.g., https://abc123.ngrok-free.app/v1)
NGROK_URL=https://PLACEHOLDER.ngrok-free.app/v1
LLM_MODEL=qwen2.5:7b
LLM_TEMPERATURE=0.4

# --- Critic Configuration ---
# Maximum retry attempts before the critic force-passes a step
MAX_CRITIC_RETRIES=2

# --- Logging ---
LOG_LEVEL=DEBUG
