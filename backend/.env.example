# =============================================================
# Alex-RTR Backend Environment Configuration
# =============================================================

# --- Groq LLM Configuration ---
# Get your key at https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_1=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_2=YOUR_GROQ_API_KEY_HERE

# --- Critic Configuration ---
# Maximum retry attempts before the critic force-passes a step
MAX_CRITIC_RETRIES=2

# --- Memory Management ---
# Summarize chat history when it exceeds this many turns
MESSAGE_SUMMARY_THRESHOLD=6

# --- Web Tools ---
# Serper API key for web search (https://serper.dev)
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE
# Firecrawl API key for web scraping (https://firecrawl.dev)
FIRECRAWL_API_KEY=YOUR_FIRECRAWL_API_KEY_HERE

# --- Logging ---
LOG_LEVEL=DEBUG
